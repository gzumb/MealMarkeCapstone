  <style>
    body { background: var(--bg-alt); }
    .tos-wrap {
      max-width: 760px; margin: 0 auto; padding: 2.5rem 1.5rem;
    }
    .tos-header {
      background: var(--umb-blue-dark); color: #fff;
      border-radius: var(--r-lg) var(--r-lg) 0 0;
      padding: 2rem 2.5rem;
    }
    .tos-header h1 {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 1.75rem; margin-bottom: .35rem;
    }
    .tos-header p { font-size: .875rem; color: rgba(255,255,255,.65); }
    .accent-bar { height: 4px; background: linear-gradient(90deg, var(--umb-blue), var(--umb-gold), var(--umb-red)); }
    .tos-body {
      background: #fff; border: 1px solid var(--border);
      border-top: none; border-radius: 0 0 var(--r-lg) var(--r-lg);
      padding: 2.5rem;
    }
    .tos-section { margin-bottom: 2rem; }
    .tos-section h2 {
      font-family: 'Source Serif 4', Georgia, serif;
      font-size: 1.1rem; color: var(--umb-blue-dark);
      margin-bottom: .75rem;
      padding-bottom: .5rem;
      border-bottom: 2px solid var(--border);
    }
    .tos-section p, .tos-section li {
      font-size: .9rem; color: var(--text-md);
      line-height: 1.75; margin-bottom: .5rem;
    }
    .tos-section ul { padding-left: 1.25rem; }
    .tos-section li { margin-bottom: .35rem; }
    .highlight-box {
      background: #fee2e2; border-left: 4px solid var(--umb-red);
      border-radius: var(--r); padding: 1rem 1.25rem;
      margin: 1rem 0; font-size: .875rem; color: #7a2e15; line-height: 1.7;
    }
    .highlight-box strong { color: var(--umb-red-dk); }
    .info-box {
      background: var(--umb-blue-lt); border-left: 4px solid var(--umb-blue);
      border-radius: var(--r); padding: 1rem 1.25rem;
      margin: 1rem 0; font-size: .875rem; color: var(--umb-blue-dark); line-height: 1.7;
    }
    .back-link {
      display: inline-flex; align-items: center; gap: .4rem;
      color: var(--umb-blue); text-decoration: none; font-size: .85rem;
      font-weight: 700; margin-bottom: 1.25rem;
    }
    .back-link:hover { text-decoration: underline; }
    .effective-date {
      font-size: .8rem; color: var(--muted); text-align: right;
      padding-top: 1.5rem; border-top: 1px solid var(--border);
    }
  </style>
</head>
<body>
<div class="tos-wrap">

  <a href="index.html" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    Back to Sign In
